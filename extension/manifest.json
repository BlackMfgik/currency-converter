{
  "manifest_version": 3,
  "name": "Конвертер валют",
  "description": "Виділіть текст з валютою — отримайте миттєву конвертацію в гривні (UAH)",
  "version": "1.0.1",
  "permissions": ["storage"],
  "host_permissions": [
    "https://open.er-api.com/*",
    "https://api.frankfurter.app/*",
    "https://cdn.jsdelivr.net/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["popup.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Конвертер валют",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
